function Font6x8Row(ch: Char; row: Integer): Byte;
var c: Integer;
begin
  if (row < 0) or (row > 7) then Exit(0);
  c := Ord(ch);
  if (c < FONT6X8_FIRST) or (c > FONT6X8_LAST) then Exit(0);
  Result := FONT6X8[c, row];
end;

